# ── Slack App credentials ─────────────────────────────────────────────────────
# Create your Slack App at https://api.slack.com/apps

# Bot token — OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Your Slack User ID (the user who receives digests)
# Find it: Slack → click your name → Profile → ... → Copy member ID
SLACK_USER_ID=U0XXXXXXXXX

# App-level token — Basic Information → App-Level Tokens → create with connections:write scope
SLACK_APP_TOKEN=xapp-your-app-token-here

# Anthropic API key — https://console.anthropic.com → API Keys → Create
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server port
PORT=3000
