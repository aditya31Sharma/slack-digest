# ── Slack App credentials ─────────────────────────────────────────────────────
# Create / reinstall your Slack App at https://api.slack.com/apps

# Bot token — OAuth & Permissions → Bot User OAuth Token (starts xoxb-)
# Bot scopes needed: chat:write, im:history, im:read, im:write
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token — Basic Information → App-Level Tokens → scope connections:write (starts xapp-)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Your Slack User ID (who gets the daily digest). Slack → your name → Profile → ... → Copy member ID
SLACK_USER_ID=U0XXXXXXXXX

# Server port (health/JSON endpoint; the bot itself runs over Socket Mode)
PORT=3000

# ── Shopify store tokens (sales data) ─────────────────────────────────────────
# LOCAL: by default the bot reads the shared multi-store .env at culture-circle-inventory/.env.
# Override that path if needed:
# SHOPIFY_ENV_PATH=/absolute/path/to/.env
#
# HOSTING (Koyeb etc., where that file does not exist): instead set one pair per store
# directly as env vars and the bot will use them:
#   MYUGEN_SHOPIFY_ACCESS_TOKEN=shpat_xxx
#   MYUGEN_SHOPIFY_DOMAIN=xfjetw-dv.myshopify.com
#   VOYD_SHOPIFY_ACCESS_TOKEN=shpat_xxx
#   VOYD_SHOPIFY_DOMAIN=voyd-6212.myshopify.com
#   ...one pair per brand
