# Copy to functions/.env and fill in real values. Firebase v2 loads functions/.env at deploy.
# (Never commit the real .env.)

# ── Slack ──
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...        # Slack app → Basic Information → Signing Secret (HTTP slash needs this)
SLACK_USER_ID=U0ABDKLF11U       # who receives the daily 12pm digest

